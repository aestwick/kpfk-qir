NEXT_PUBLIC_SUPABASE_URL=https://czjhwhfqohpmwprhasve.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GROQ_API_KEY=
# Optional fallback transcription providers (priority + enable toggles set in the
# dashboard under Settings → Pipeline → Transcription Providers). Leave blank to
# skip a provider — the worker only uses providers whose key is present.
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
OPENAI_API_KEY=
REDIS_URL=redis://qir-redis:6379
NEXT_PUBLIC_APP_URL=https://qir.kpfk.org
# Cloudflare R2 (S3 API) — only for the standalone `npm run transcribe-r2` job
# (transcribe audio straight out of an R2 bucket; see scripts/transcribe-r2.ts).
# Not used by the app/workers. Omit for a public bucket and pass --public-base-url.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# R2_ENDPOINT=  # optional override; defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
