{
  "name": "qir-kpfk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "backfill-quarter": "tsx scripts/backfill-quarter.ts",
    "verify-week": "tsx scripts/verify-week.ts",
    "transcribe-r2": "tsx scripts/transcribe-r2.ts",
    "backfill-transcript-cues": "tsx scripts/backfill-transcript-cues.ts",
    "backfill-transcript-embeddings": "tsx scripts/backfill-transcript-embeddings.ts",
    "workers": "tsx workers/index.ts",
    "generate-qir": "tsx -e \"const { Queue } = require('bullmq'); const q = new Queue('generate-qir', { connection: { host: 'localhost', port: 6379 } }); const [,, ...args] = process.argv; const yearIdx = args.indexOf('--year'); const qIdx = args.indexOf('--quarter'); const year = yearIdx >= 0 ? parseInt(args[yearIdx+1]) : new Date().getFullYear(); const quarter = qIdx >= 0 ? parseInt(args[qIdx+1]) : Math.floor(new Date().getMonth()/3)+1; q.add('generate', { year, quarter }).then(() => { console.log('Queued QIR generation for Q'+quarter+' '+year); process.exit(0); });\"",
    "start:all": "concurrently \"npm run start\" \"npm run workers\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@supabase/supabase-js": "^2.45.0",
    "autoprefixer": "^10.4.27",
    "bullmq": "^5.12.0",
    "concurrently": "^8.2.2",
    "fast-xml-parser": "^4.4.1",
    "ioredis": "^5.11.0",
    "next": "14.2.15",
    "openai": "^4.56.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0",
    "vitest": "^2.1.8"
  }
}
